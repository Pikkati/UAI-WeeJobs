{
  "name": "my-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "node -r ./__jest_global_window.js ./node_modules/.bin/jest --config=jest.config.cjs --watchAll",
    "test:autowatch": "node scripts/auto-jest-watch.js",
    "test:q": "node scripts/auto-jest-watch.js",
    "test:ci:retry": "node scripts/run-tests-with-retries.js",
    "update:badges": "node scripts/update-readme-badges.js",
    "type": "tsc --noEmit",
    "build:staging": "eas build --platform all --profile preview --non-interactive",
    "start:webhook": "node scripts/stripe-webhook.js",
    "lint": "expo lint",
    "ci:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-act.ps1 && .\\.bin\\act.exe -j \"check-base\" -P ubuntu-latest=nektos/act-environments-ubuntu:18.04 --env-file .env --secret EAS_TOKEN=placeholder",
    "ci:local:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-act.ps1 && .\\.bin\\act.exe -P ubuntu-latest=nektos/act-environments-ubuntu:18.04 --env-file .env --secret EAS_TOKEN=placeholder",
    "ci": "npm run ci:local"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@supabase/supabase-js": "^2.100.1",
    "expo": "^55.0.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-native": "^0.84.1",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.8.1",
    "stripe": "^21.0.1"
  },
  "optionalDependencies": {
    "@sentry/react-native": "^5.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "babel-preset-expo": "^55.0.13",
    "eslint": "^10.1.0",
    "eslint-config-expo": "~55.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jest-expo": "^47.0.1",
    "lint-staged": "^16.4.0",
    "react-test-renderer": "19.2.4",
    "semantic-release": "^25.0.3",
    "typescript": "~6.0.2"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx,jsx}": [
      "npm run type",
      "npx --no-install eslint --fix"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "npx lint-staged"
    }
  },
  "private": true
}
