{
  "name": "my-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "assets:check-rtl": "node scripts/check-rtl-assets.js",
    "optimize:assets": "node scripts/optimize-assets.js",
    "smoke": "node --max-old-space-size=4096 node_modules/jest/bin/jest.js '.*smoke.*' --runInBand -i",
    "test:ci": "node --max-old-space-size=4096 node_modules/jest/bin/jest.js --coverage --runInBand -i",
    "coverage": "npm run test:ci",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "launch:avd": "powershell -File ./scripts/launch_avd.ps1",
    "verify:android": "powershell -File ./scripts/run_verify_debug.ps1",
    "verify:android:unix": "./scripts/run_verify_debug.sh",
    "patch:bundle-inspector": "node ./scripts/insert_router_inspector.js",
    "pull:inspector": "node ./scripts/pull_inspector.js",
    "parse:inspector": "node ./scripts/parse_inspector.js",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "node -r ./__jest_global_window.js ./node_modules/jest/bin/jest.js --config=jest.config.cjs --watchAll",
    "test:smoke": "node -r ./__jest_global_window.js ./node_modules/jest/bin/jest.js __tests__/smoke.harness.test.tsx --config=jest.config.cjs -i",
    "test:autowatch": "node scripts/auto-jest-watch.js",
    "test:q": "node --max-old-space-size=4096 node_modules/jest/bin/jest.js -i",
    "test:ci:retry": "node scripts/run-tests-with-retries.js",
    "update:badges": "node scripts/update-readme-badges.js",
    "type": "tsc --noEmit",
    "lint": "eslint . --cache"
  },
  "assetsScripts": {
    "pngSprite": "node scripts/png-sprite.js",
    "lottieFallbacks": "node scripts/lottie-fallbacks.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "7.11.0",
    "@stripe/stripe-react-native": "0.58.0",
    "@supabase/supabase-js": "^2.100.1",
    "eslint-plugin-react": "7.33.2",
    "expo": "^55.0.9",
    "expo-file-system": "^55.0.12",
    "expo-image-picker": "^55.0.14",
    "expo-linear-gradient": "^55.0.9",
    "expo-linking": "^55.0.9",
    "expo-router": "^55.0.8",
    "expo-splash-screen": "^55.0.13",
    "expo-status-bar": "^55.0.4",
    "expo-updates": "^55.0.16",
    "pg": "^8.11.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@playwright/test": "^1.59.1",
    "@react-native-community/cli": "latest",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "^55.0.13",
    "eslint": "^8.0.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-expo": "^55.0.11",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.4.0",
    "react-test-renderer": "^19.2.0",
    "semantic-release": "^25.0.3",
    "sharp": "^0.32.1",
    "svgo": "^3.1.0",
    "typescript": "^5.0.0"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx,jsx}": [
      "npm run type",
      "npx --no-install eslint --fix"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "npx lint-staged"
    }
  },
  "private": true
}
