########################################
# Environment variables for WeeJobs
########################################

# Stripe (required for payments & webhooks)
# - STRIPE_SECRET: Your Stripe secret key (used by server-side functions)
# - STRIPE_ENDPOINT_SECRET: Webhook signing secret for verifying webhook payloads
STRIPE_SECRET=
STRIPE_ENDPOINT_SECRET=

# Supabase (required for app runtime)
# - EXPO_PUBLIC_SUPABASE_URL: Public URL of your Supabase project
# - EXPO_PUBLIC_SUPABASE_ANON_KEY: Public anon key used by client SDKs
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# API base (optional)
# - EXPO_PUBLIC_API_BASE: Base URL for any small API or Supabase Edge Functions
#   Example for local dev: http://localhost:54321/functions/v1
#   When empty, client-side resend/aux endpoints will be disabled.
EXPO_PUBLIC_API_BASE=

# Sentry (optional)
# - EXPO_PUBLIC_SENTRY_DSN: Public DSN for Sentry (client-side reporting)
EXPO_PUBLIC_SENTRY_DSN=

# Expo/Platform hints (usually set by Expo/runtime)
# - EXPO_OS: runtime platform (ios|android|web)
# - EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY: Stripe publishable key for client SDK
EXPO_OS=
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Add any other required EXPO_ or API keys below.
